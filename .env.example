# SkillAdaptor local secrets template
# ---------------------------------------------------------------------------
# 1. Copy this file to:  secrets/.env
# 2. Fill in your real API keys and local benchmark paths
# 3. NEVER commit secrets/.env (it is gitignored)
#
# Load into shell:
#   . scripts/load_secrets.ps1        # Windows PowerShell
#   source scripts/load_secrets.sh    # Linux / macOS
# ---------------------------------------------------------------------------

SkillAdaptor_PROVIDER=auto
SkillAdaptor_BENCHMARK_ENV=pinchbench

# === Chat LLM — API key + base URL (compatible /v1 endpoint) ===
# One relay can serve gpt / kimi / glm / deepseek: switch with --model only.
SkillAdaptor_BASE_URL=https://your-api.example.com/v1
SkillAdaptor_API_KEY=sk-your-key-here
SkillAdaptor_MODEL=gpt-4.1

# === Embedding — official upload default is Qwen3-Embedding-8B ===
SkillAdaptor_EMBEDDING_API_KEY=sk-your-embedding-key
SkillAdaptor_EMBEDDING_BASE_URL=https://your-embedding-api.example.com/v1
SkillAdaptor_EMBEDDING_MODEL=Qwen3-Embedding-8B
# Local-only backup if Qwen3 unavailable (secrets/.env — never change code default):
# SkillAdaptor_EMBEDDING_MODEL=text-embedding-3-small
# Paper S_q: embed → top-10 → LLM rerank (default on). Opt out only for A/B:
# SkillAdaptor_LLM_RERANK=0
# Paper-strict: skip skill edit on reasoning_wrong (default is evolve/patch anyway):
# SKILLADAPTOR_SKIP_REASONING_WRONG_EVOLVE=1

# === Benchmark install paths (absolute paths on your machine) ===
PINCHBENCH_PATH=/path/to/pinchbench
PINCHBENCH_PYTHON=/path/to/python-with-openclaw
PINCHBENCH_TMP=/tmp

CLAW_EVAL_PATH=/path/to/claw-eval
CLAW_EVAL_TASKS_DIR=tasks
# CLAW_EVAL_PYTHON=/path/to/python
#
# === Claw-Eval OFFICIAL judge (submitted / paper path) ===
# Same OpenAI-compatible interface everywhere: URL + key.
# model_id is locked in code to google/gemini-3-flash-preview (config_general.yaml).
CLAW_EVAL_JUDGE_API_KEY=sk-or-v1-your-openrouter-or-compatible-key
CLAW_EVAL_JUDGE_BASE_URL=https://openrouter.ai/api/v1
# Or: OPENROUTER_API_KEY=sk-or-v1-...   (base defaults to OpenRouter)
#
# Do NOT set CLAW_EVAL_JUDGE_MODEL for paper runs.
# Paper Pass@3: CLAW_EVAL_TRIALS=3
# Local wiring when Gemini unreachable (helper is gitignored — keep local only):
#   CLAW_EVAL_ALLOW_NONOFFICIAL_JUDGE=1   # never for paper / upload claims

WEBSHOP_PATH=/path/to/WebShop
WEBSHOP_PYTHON=/path/to/conda/envs/webshop/python

# === OpenClaw harness (default for plugin / PinchBench / Claw-Eval) ===
# npm install -g openclaw && openclaw gateway start
# Windows if `openclaw` not on PATH:
# OPENCLAW_CLI=C:\Users\you\AppData\Roaming\npm\openclaw.cmd
# Skill inject path: ~/.openclaw/workspace/skills/skill-adaptor-evolved/SKILL.md

# === Optional: alternate chat provider (own key + base URL; falls back to SkillAdaptor_API_*) ===
# DeepSeek is compatible — you can also keep PROVIDER=auto and set SkillAdaptor_BASE_URL to DeepSeek.
# SkillAdaptor_PROVIDER=deepseek
# DEEPSEEK_API_KEY=sk-your-deepseek-key
# DEEPSEEK_API_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_MODEL=deepseek-chat
#
# OpenRouter uses vendor/model ids (e.g. openai/gpt-4.1).
# SkillAdaptor_PROVIDER=openrouter
# OPENROUTER_API_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_API_KEY=sk-or-v1-your-key
# OPENROUTER_MODEL=openai/gpt-4.1

# === Optional runtime ===
# SkillAdaptor_GLOBAL_LOCK=C:/path/to/custom-global.lock

# === Algorithm defaults (usually leave as-is) ===
SkillAdaptor_MAX_ITERATIONS=10
SkillAdaptor_SUCCESS_DELTA_THRESHOLD=0.005
SkillAdaptor_AVG_SCORE_DELTA_THRESHOLD=0.005
SkillAdaptor_REGRESSION_THRESHOLD=-0.05
SkillAdaptor_MIN_SAMPLE_SIZE=5
SkillAdaptor_MAX_RETRIES=5
# PinchBench / workspace default floor; Claw-Eval forces 0.45 via ClawEvalConfig
SkillAdaptor_SKILL_MATCH_THRESHOLD=0.50
SkillAdaptor_CROSS_TASK_MATCH_THRESHOLD=0.55

# === SkillNet optional hooks (pip install skillnet-ai) ===
# SKILLNET_ENABLED=0
