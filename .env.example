# SkillAdaptor local secrets template
# ---------------------------------------------------------------------------
# 1. Copy this file to:  secrets/.env
# 2. Fill in your real API keys and local benchmark paths
# 3. NEVER commit secrets/.env (it is gitignored)
#
# Load into shell:
#   . scripts/load_secrets.ps1        # Windows PowerShell
#   source scripts/load_secrets.sh    # Linux / macOS
# ---------------------------------------------------------------------------

SkillAdaptor_PROVIDER=auto
SkillAdaptor_BENCHMARK_ENV=pinchbench

# === Chat LLM — one OpenAI-compatible API (gpt / kimi / glm / deepseek: use --model only) ===
OPENAI_API_BASE_URL=https://your-api.example.com/v1
OPENAI_API_KEY=sk-your-key-here
SkillEvolve_MODEL=gpt-4.1

# === Embedding — separate API for skill–task matching ===
SkillEvolve_EMBEDDING_API_KEY=sk-your-embedding-key
SkillEvolve_EMBEDDING_BASE_URL=https://your-embedding-api.example.com/v1
SkillEvolve_EMBEDDING_MODEL=text-embedding-3-small

# === Benchmark install paths (absolute paths on your machine) ===
PINCHBENCH_PATH=/path/to/pinchbench
PINCHBENCH_PYTHON=/path/to/python-with-openclaw
PINCHBENCH_TMP=/tmp

CLAW_EVAL_PATH=/path/to/claw-eval
CLAW_EVAL_TASKS_DIR=tasks
# CLAW_EVAL_PYTHON=/path/to/python

WEBSHOP_PATH=/path/to/WebShop
WEBSHOP_PYTHON=/path/to/conda/envs/webshop/python

# === Optional: alternate chat provider (only if SkillAdaptor_PROVIDER is set) ===
# SkillAdaptor_PROVIDER=deepseek
# DEEPSEEK_API_KEY=sk-your-deepseek-key
# DEEPSEEK_API_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat
#
# SkillAdaptor_PROVIDER=openrouter
# OPENROUTER_API_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_API_KEY=sk-or-v1-your-key
# OPENROUTER_MODEL=openai/gpt-4.1

# === Optional runtime ===
# SkillAdaptor_GLOBAL_LOCK=C:/path/to/custom-global.lock
# OPENCLAW_CLI=C:\Users\you\AppData\Roaming\npm\openclaw.cmd

# === Algorithm defaults (usually leave as-is) ===
SkillEvolve_MAX_ITERATIONS=10
SkillEvolve_SUCCESS_DELTA_THRESHOLD=0.005
SkillEvolve_AVG_SCORE_DELTA_THRESHOLD=0.005
SkillEvolve_REGRESSION_THRESHOLD=-0.05
SkillEvolve_MIN_SAMPLE_SIZE=5
SkillEvolve_MAX_RETRIES=5
SkillEvolve_SKILL_MATCH_THRESHOLD=0.50
SkillEvolve_CROSS_TASK_MATCH_THRESHOLD=0.55

# === SkillNet optional hooks (pip install skillnet-ai) ===
# SKILLNET_ENABLED=0
