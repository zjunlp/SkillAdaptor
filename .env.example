# SkillAdaptor local secrets template
# ---------------------------------------------------------------------------
# 1. Copy this file to:  secrets/.env
# 2. Fill in your real API keys and local benchmark paths
# 3. NEVER commit secrets/.env (it is gitignored)
#
# Load into shell:
#   . scripts/load_secrets.ps1        # Windows PowerShell
# ---------------------------------------------------------------------------

# === Provider (run_plugin / run_skillevolve) ===
SkillAdaptor_PROVIDER=relay-gpt41
SkillAdaptor_BENCHMARK_ENV=pinchbench

# === Primary LLM — OpenAI-compatible relay or official API ===
OPENAI_API_BASE_URL=https://your-relay-or-api.example.com/v1
OPENAI_API_KEY=sk-your-key-here
# Optional backup endpoints (leave unset if unused)
# OPENAI_API_BASE_URL_BACKUP=https://backup.example.com/v1
# OPENAI_API_KEY_BACKUP_1=sk-backup-1
# OPENAI_API_KEY_BACKUP_2=sk-backup-2

# SkillAdaptor aliases (usually same as OPENAI_* above)
SkillEvolve_API_KEY=sk-your-key-here
SkillEvolve_BASE_URL=https://your-relay-or-api.example.com/v1
SkillEvolve_MODEL=gpt-4.1

# === Embedding (skill–task matching; often same relay as chat) ===
SkillEvolve_EMBEDDING_API_KEY=sk-your-key-here
SkillEvolve_EMBEDDING_BASE_URL=https://your-relay-or-api.example.com/v1
SkillEvolve_EMBEDDING_MODEL=Qwen3-Embedding-8B
# Backup embedding model (manual switch only; runtime does not auto-fallback on Qwen3 failure):
# SkillEvolve_EMBEDDING_MODEL=text-embedding-3-small

# === DeepSeek (optional — set SkillAdaptor_PROVIDER=deepseek) ===
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_API_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# === OpenRouter (optional — set SkillAdaptor_PROVIDER=openrouter) ===
OPENROUTER_API_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_API_KEY=sk-or-v1-your-key
OPENROUTER_MODEL=deepseek/deepseek-chat

# === Benchmark install paths (absolute paths on your machine) ===
PINCHBENCH_PATH=/path/to/pinchbench
PINCHBENCH_PYTHON=/path/to/python-with-openclaw
PINCHBENCH_TMP=/tmp

CLAW_EVAL_PATH=/path/to/claw-eval
CLAW_EVAL_TASKS_DIR=tasks
# CLAW_EVAL_PYTHON=/path/to/python

WEBSHOP_PATH=/path/to/WebShop
WEBSHOP_PYTHON=/path/to/conda/envs/webshop/python

# === Optional runtime ===
# Only one evolution run machine-wide (default: %TEMP%/skill-adaptor-global.lock)
# SkillAdaptor_GLOBAL_LOCK=C:/path/to/custom-global.lock

# === Algorithm defaults (usually leave as-is) ===
SkillEvolve_MAX_ITERATIONS=10
SkillEvolve_SUCCESS_DELTA_THRESHOLD=0.005
SkillEvolve_AVG_SCORE_DELTA_THRESHOLD=0.005
SkillEvolve_REGRESSION_THRESHOLD=-0.05
SkillEvolve_MIN_SAMPLE_SIZE=5
SkillEvolve_MAX_RETRIES=5
SkillEvolve_SKILL_MATCH_THRESHOLD=0.50
SkillEvolve_CROSS_TASK_MATCH_THRESHOLD=0.55

# Optional: explicit openclaw path if not on PATH
# OPENCLAW_CLI=C:\Users\you\AppData\Roaming\npm\openclaw.cmd

# === SkillNet optional hooks (pip install skillnet-ai) ===
# API_KEY=sk-your-key-here
# BASE_URL=https://your-relay-or-api.example.com/v1
# SKILLNET_MODEL=gpt-4.1
# SKILLNET_ENABLED=0
# SKILLNET_POST_EVAL=0
# SKILLNET_POST_ANALYZE=0
