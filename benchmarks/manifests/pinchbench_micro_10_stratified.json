{
  "name": "pinchbench_micro_10_stratified",
  "description": "10-task disjoint PinchBench — retrieval: manifest labels + category gate + embedding.",
  "benchmark": "pinchbench",
  "input_tasks": [
    "task_git_rescue_recovery",
    "task_shell_command_generator",
    "task_selector_fix",
    "task_log_ssh_brute_force",
    "task_spreadsheet_summary"
  ],
  "validation_tasks": [
    "task_log_nginx_errors",
    "task_test_generation",
    "task_playwright_e2e",
    "task_multi_file_refactoring",
    "task_sanity"
  ],
  "test_tasks": [
    "task_k8s_debugging",
    "task_csv_data_processing"
  ],
  "allow_train_val_overlap": false,
  "probe_mode": false,
  "retrieval": {
    "policy": {
      "require_category_match": true,
      "allow_cross_category": false,
      "same_category_embed_min": 0.50,
      "cross_task_embed_min": 0.55,
      "cross_category_embed_min": 0.72
    },
    "task_labels": {
      "task_git_rescue_recovery": { "category": "coding", "tags": ["git", "vcs", "recovery"] },
      "task_shell_command_generator": { "category": "coding", "tags": ["shell", "bash"] },
      "task_selector_fix": { "category": "coding", "tags": ["dom", "selector"] },
      "task_log_ssh_brute_force": { "category": "log_analysis", "tags": ["ssh", "log"] },
      "task_spreadsheet_summary": { "category": "analysis", "tags": ["spreadsheet", "xlsx"] },
      "task_log_nginx_errors": { "category": "log_analysis", "tags": ["nginx", "log"] },
      "task_test_generation": { "category": "coding", "tags": ["test", "pytest"] },
      "task_playwright_e2e": { "category": "coding", "tags": ["playwright", "e2e"] },
      "task_multi_file_refactoring": { "category": "coding", "tags": ["refactor"] },
      "task_sanity": { "category": "productivity", "tags": ["sanity"] },
      "task_k8s_debugging": { "category": "coding", "tags": ["k8s"] },
      "task_csv_data_processing": { "category": "analysis", "tags": ["csv"] }
    }
  }
}
