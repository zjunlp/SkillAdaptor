{
  "name": "pinchbench_mix_b5",
  "description": "Alternate 5-task PinchBench evolution (different from smoke_5). Includes spreadsheet (331 analog) + log/shell/selector/test domains.",
  "benchmark": "pinchbench",
  "input_tasks": [
    "task_spreadsheet_summary",
    "task_log_nginx_errors",
    "task_shell_command_generator",
    "task_selector_fix",
    "task_test_generation"
  ],
  "validation_tasks": [
    "task_spreadsheet_summary",
    "task_log_nginx_errors",
    "task_shell_command_generator",
    "task_selector_fix",
    "task_test_generation"
  ],
  "test_tasks": [
    "task_log_nginx_errors",
    "task_selector_fix",
    "task_test_generation"
  ],
  "allow_train_val_overlap": true,
  "probe_mode": true,
  "notes": {
    "max_iterations_recommended": 2,
    "requires": ["PINCHBENCH_PATH", "OpenClaw Gateway", "SkillEvolve_API_KEY"],
    "rationale": "Cross-domain generalization test vs smoke5_v02 git-only adoption"
  }
}
